//@version=6
library("HanJinSignals26", overlay = true)

// ─── Internal geometry helpers (not exported) ─────────────────────
wickFracs() =>
    rng = high - low
    up  = rng > 0 ? (high - math.max(open, close)) / rng : na
    lo  = rng > 0 ? (math.min(open, close) - low)  / rng : na
    [up, lo]

bodyFrac() =>
    rng = high - low
    rng > 0 ? math.abs(close - open) / rng : na

bodyDirAt(series int off) =>
    close[off] > open[off] ? 1 : close[off] < open[off] ? -1 : 0

contains(series int outer, series int inner) =>
    high[outer] >= high[inner] and low[outer] <= low[inner]

reverseOf(series int parentOff) =>
    d = bodyDirAt(parentOff)
    d > 0 ? "SELL" : d < 0 ? "BUY" : na

// ─── ① Pinbar ─────────────────────────────────────────────────────
export pinbar(simple float longFrac = 0.667, simple float shortFrac = 0.2, simple bool strict = true) =>
    [up, lo] = wickFracs()
    bull = not na(lo) and lo >= longFrac and (not strict or up <= shortFrac)
    bear = not na(up) and up >= longFrac and (not strict or lo <= shortFrac)
    bull ? "BUY" : bear ? "SELL" : na

// ─── ② Engulfing ──────────────────────────────────────────────────
export engulf() =>
    pBh = math.max(open[1], close[1])
    pBl = math.min(open[1], close[1])
    cBh = math.max(open, close)
    cBl = math.min(open, close)
    ok  = high >= high[1] and low <= low[1] and cBh >= pBh and cBl <= pBl
    dir = bodyDirAt(0)
    ok and dir > 0 ? "BUY" : ok and dir < 0 ? "SELL" : na

// ─── ③ Fractal — returns [topSide, botSide] ───────────────────────
// Strict structural fractal (NOT a pivot): middle candle must dominate both
// neighbours on BOTH the high line AND the low line — inverted-V / V on all 4.
//   bar[2]=left  bar[1]=middle  bar[0]=right confirmation
export fractal() =>
    top = high[1] > high[2] and high[1] > high[0] and low[1] > low[2] and low[1] > low[0]
    bot = low[1] < low[2] and low[1] < low[0] and high[1] < high[2] and high[1] < high[0]
    [top ? "SELL" : na, bot ? "BUY" : na]
// ─── ④ Harami + ④b Double Harami — returns [single, double] ──────
export harami() =>
    h0 = contains(1, 0)
    h1 = contains(2, 1)
    [h0 ? reverseOf(1) : na, (h0 and h1) ? reverseOf(2) : na]

// ─── ⑤ Big Body ───────────────────────────────────────────────────
export bigbody(simple float minFrac = 0.7) =>
    bf  = bodyFrac()
    dir = bodyDirAt(0)
    ok  = not na(bf) and bf >= minFrac
    ok and dir > 0 ? "BUY" : ok and dir < 0 ? "SELL" : na


// ─── Squeeze Sideways ──────────────────────────────────────────────
// Returns true when LazyBear SQZMOM black dot appears.
// reference: Squeeze Momentum Indicator [LazyBear]
export isSideways(
     simple int bbLen = 60,
     simple int kcLen = 60,
     simple float kcMult = 1.5,
     simple bool useTrueRange = true
) =>
    source = close

    bbBasis = ta.sma(source, bbLen)
    bbDev = kcMult * ta.stdev(source, bbLen)
    upperBB = bbBasis + bbDev
    lowerBB = bbBasis - bbDev

    kcBasis = ta.sma(source, kcLen)
    priceRange = useTrueRange ? ta.tr(true) : high - low
    rangeMa = ta.sma(priceRange, kcLen)
    upperKC = kcBasis + rangeMa * kcMult
    lowerKC = kcBasis - rangeMa * kcMult

    lowerBB > lowerKC and upperBB < upperKC

// Returns [touchUpper, touchLower]
export touchBollingerBand(series float upperBand, series float lowerBand) =>
    touchUpper = high >= upperBand
    touchLower = low <= lowerBand
    [touchUpper, touchLower]


// ─── Position Helpers ──────────────────────────────────────────────
export hasPosition(series float positionSize) =>
    positionSize != 0

export isLongPosition(series float positionSize) =>
    positionSize > 0

export isShortPosition(series float positionSize) =>
    positionSize < 0

export isFlatPosition(series float positionSize) =>
    positionSize == 0

secret = "demo-secret-change-me"
// ─── Repository: webhook payload ───────────────────────────────────
export payload(string side, string tag) =>
    '{"secret":"' + secret +
      '","id":"'  + tag + '-' + side + '-{{timenow}}"' +
      ',"ts":"{{timenow}}"' +
      ',"symbol":"' + syminfo.ticker +
      '","side":"' + side +
      '","comment":"' + tag + '"}'


// ─── Futures risk helpers ──────────────────────────────────────────
export planFuturesContracts(
     float accountEquityUsd,
     float riskPct,
     float entryPrice,
     float stopLossPrice,
     float usdPerPointPerContract,
     float minSizingRiskPoints,
     int maxContracts
) =>
    actualRiskPoints = math.abs(entryPrice - stopLossPrice)

    sizingRiskPoints = math.max(actualRiskPoints, minSizingRiskPoints)

    riskBudgetUsd = accountEquityUsd * riskPct / 100.0

    riskUsdPerContract = sizingRiskPoints * usdPerPointPerContract

    rawContracts = riskUsdPerContract > 0 ? riskBudgetUsd / riskUsdPerContract : 0.0

    contracts = int(math.floor(rawContracts))

    cappedContracts = math.min(contracts, maxContracts)

    [cappedContracts, actualRiskPoints, sizingRiskPoints, riskBudgetUsd, riskUsdPerContract]


export splitContracts(int totalContracts) =>
    firstHalfContracts = int(math.floor(totalContracts / 2))
    secondHalfContracts = totalContracts - firstHalfContracts

    [firstHalfContracts, secondHalfContracts]