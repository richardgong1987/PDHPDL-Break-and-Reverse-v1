//@version=6
strategy("PDH/PDL Break & Reverse v1", overlay = true,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     pyramiding              = 1,
     calc_on_every_tick      = false,
     process_orders_on_close = true,
     initial_capital         = 100000,
     currency                = currency.USD,
     margin_long             = 1,
     margin_short            = 1)

// ─── Inputs ────────────────────────────────────────────────────────
riskPct       = input.float(1.0, "Risk % per trade",   0.1, 10.0, 0.1, group = "Risk")
stopOffTicks  = input.int  (15,  "Stop offset (ticks)", 0, 1000,       group = "Risk")
breakOffTicks = input.int  (15,  "Breakeven + ticks",   0, 1000,       group = "Risk")
tp1R          = input.float(2.0, "TP1 (R), 50% off",    0.5, 20.0, 0.1, group = "Risk")
tp2R          = input.float(4.0, "TP2 (R), runner",     0.5, 20.0, 0.1, group = "Risk")
secret        = input.string("demo-secret-change-me", "Webhook secret", group = "Bridge")
showDbg       = input.bool (false, "Show debug plots", group = "Debug")

// ─── Reader: previous-day levels + offsets ─────────────────────────
// lookahead_on is safe ONLY because the requested expression is already
// shifted by [1] (a previous, completed daily value) — never request a
// same-day value this way.
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]],lookahead = barmerge.lookahead_on)
tickOff  = syminfo.mintick * stopOffTicks
breakOff = syminfo.mintick * breakOffTicks

// ─── Parser: false-breakout geometry ───────────────────────────────
haveLevels     = not na(pdh) and not na(pdl)
falseBreakUp   = haveLevels and high > pdh and close < pdh   // -> SHORT
falseBreakDown = haveLevels and low  < pdl and close > pdl   // -> LONG

// ─── Service: per-position state (single bounded context) ──────────
var float gEntry  = na
var float gStop   = na
var float gRisk   = na
var int   gDir    = 0       // 0 flat, 1 long, -1 short
var bool  gBE     = false   // 1-R breakeven push already applied
var bool  gOpened = false   // entry order has actually filled

// ─── Validator: flat-position gate ─────────────────────────────────
noPos     = gDir == 0 and strategy.position_size == 0
longTrig  = noPos and falseBreakDown
shortTrig = noPos and falseBreakUp

// prospective stop / risk (entry = close); single source reused by planners
stopLong  = low  - tickOff
stopShort = high + tickOff
riskLong  = close - stopLong
riskShort = stopShort - close

// ─── Service: pure planners (≤ 30 lines, ≤ 3 args, no I/O) ─────────
planLong() =>
    qty = riskLong > 0 ? (strategy.equity * riskPct / 100.0) / riskLong : 0.0
    [close, stopLong, riskLong, qty]

planShort() =>
    qty = riskShort > 0 ? (strategy.equity * riskPct / 100.0) / riskShort : 0.0
    [close, stopShort, riskShort, qty]

beStop() =>
    gDir > 0 ? gEntry + breakOff : gEntry - breakOff

// ─── Repository: webhook payload ───────────────────────────────────
payload(string side, string tag) =>
    '{"secret":"' + secret +
      '","id":"'  + tag + '-' + side + '-{{timenow}}"' +
      ',"ts":"{{timenow}}"' +
      ',"symbol":"' + syminfo.ticker +
      '","side":"' + side +
      '","comment":"' + tag + '"}'

// ─── Orchestrator ──────────────────────────────────────────────────
// Flow:
// 1. Read PDH/PDL                 (Reader)
// 2. Parse false-breakout flags   (Parser)
// 3. Validate triggers            (Validator)
// 4. Open if flat and trigger
// 5. Push breakeven at +1 R
// 6. Reset state on close

// Step 4: Open — only when fully flat (one position at a time; no add / reverse)
if noPos and barstate.isconfirmed
    if longTrig
        [entry, stop, risk, qty] = planLong()
        if qty > 0
            gEntry  := entry
            gStop   := stop
            gRisk   := risk
            gDir    := 1
            gBE     := false
            gOpened := false
            strategy.entry("L", strategy.long, qty = qty)
            strategy.exit ("TP1_L",  from_entry = "L", qty_percent = 50, limit = entry + tp1R * risk)
            strategy.exit ("MAIN_L", from_entry = "L", stop = stop,      limit = entry + tp2R * risk)
            alert(payload("BUY", "pdhpdl-v1"), alert.freq_once_per_bar_close)
    else if shortTrig
        [entry, stop, risk, qty] = planShort()
        if qty > 0
            gEntry  := entry
            gStop   := stop
            gRisk   := risk
            gDir    := -1
            gBE     := false
            gOpened := false
            strategy.entry("S", strategy.short, qty = qty)
            strategy.exit ("TP1_S",  from_entry = "S", qty_percent = 50, limit = entry - tp1R * risk)
            strategy.exit ("MAIN_S", from_entry = "S", stop = stop,      limit = entry - tp2R * risk)
            alert(payload("SELL", "pdhpdl-v1"), alert.freq_once_per_bar_close)

// Step 5a: detect actual fill (transition from no position to position)
if not gOpened and strategy.position_size != 0
    gOpened := true

// Step 5b: push stop to breakeven once floating P/L ≥ 1 R
if gDir == 1 and not gBE and high >= gEntry + gRisk
    gBE := true
    strategy.exit("MAIN_L", from_entry = "L", stop = beStop(), limit = gEntry + tp2R * gRisk)

if gDir == -1 and not gBE and low <= gEntry - gRisk
    gBE := true
    strategy.exit("MAIN_S", from_entry = "S", stop = beStop(), limit = gEntry - tp2R * gRisk)

// Step 6: reset state once position is flat again
if gOpened and strategy.position_size == 0
    gDir    := 0
    gEntry  := na
    gStop   := na
    gRisk   := na
    gBE     := false
    gOpened := false

// ─── Plots ─────────────────────────────────────────────────────────
plot(pdh, "PDH", color.new(color.red,  0), style = plot.style_stepline)
plot(pdl, "PDL", color.new(color.lime, 0), style = plot.style_stepline)
plotshape(longTrig,  "Long trig",  shape.triangleup,   location.belowbar, color.lime, text = "L", size = size.small)
plotshape(shortTrig, "Short trig", shape.triangledown, location.abovebar, color.red,  text = "S", size = size.small)
